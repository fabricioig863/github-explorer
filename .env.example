# Use in-memory mocks instead of real GitHub API (default: true)
# Set to 'false' to use the real GitHub API.
EXPO_PUBLIC_USE_MOCK=false

# GitHub Personal Access Token (optional, raises rate limit from 60 to 5000 req/h).
# Generate at: https://github.com/settings/tokens
# Scope needed: public_repo (read-only).
# NOTE: prefix EXPO_PUBLIC_ is required to be bundled — but BE AWARE this
# means the token will be visible in the app bundle. Only use tokens with
# read-only scopes.
EXPO_PUBLIC_GITHUB_TOKEN=

# Username exibido na aba Perfil. App não tem auth — endpoint /users/{username}
# é público no GitHub. Sem este var, fallback = 'octocat'.
EXPO_PUBLIC_PROFILE_USERNAME=octocat
